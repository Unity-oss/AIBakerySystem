# ============================================================
# Tastyz Bakery AI System — Environment Variables
# Copy this file to .env and fill in your actual values
# For Railway deployment, set these in Railway Dashboard
# ============================================================

# ============================================================
# Django Settings
# ============================================================
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.railway.app
CSRF_TRUSTED_ORIGINS=https://your-app.railway.app,http://localhost:8000

# ============================================================
# Database (PostgreSQL on Railway)
# ============================================================
# Leave blank for local SQLite, Railway auto-injects this
DATABASE_URL=

# ============================================================
# Redis (for Celery)
# ============================================================
# Railway auto-injects this when Redis service is added
REDIS_URL=redis://localhost:6379/0

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# Google Gemini
# ============================================================
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-pro

# ============================================================
# Anthropic Claude
# ============================================================
ANTHROPIC_API_KEY=your-anthropic-key-here

# ============================================================
# Grok (xAI)
# ============================================================
GROK_API_KEY=your-grok-key-here
GROK_MODEL=grok-2

# ============================================================
# Ollama (Local LLM)
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ============================================================
# Pinecone (Optional Vector Store)
# ============================================================
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ============================================================
# LangSmith (Observability)
# ============================================================
LANGSMITH_API_KEY=

# ============================================================
# Google Calendar
# ============================================================
GOOGLE_CALENDAR_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=your-client-secret
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# ============================================================
# Stripe (Payment)
# ============================================================
STRIPE_API_KEY=sk_test_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_WEBHOOK_KEY=whsec_test_your-key-here

# ============================================================
# Flutterwave (Payment - Alternative)
# ============================================================
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# ============================================================
# Email Configuration
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
BAKER_EMAIL=baker@tastyzbakery.com

# ============================================================
# ChromaDB Path
# ============================================================
CHROMA_PERSIST_DIR=/var/data/chroma_db

# ============================================================
# Celery Configuration
# ============================================================
CELERY_BROKER_URL=$REDIS_URL
CELERY_RESULT_BACKEND=$REDIS_URL
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=Africa/Kampala
